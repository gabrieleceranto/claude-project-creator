[Unit]
Description=Creator Dashboard (Next.js)
After=network.target

[Service]
Type=simple
User=gabriele
WorkingDirectory=/home/gabriele/workspace/creator
ExecStart=/usr/bin/npm run dev
Restart=on-failure
RestartSec=5
Environment=NODE_ENV=development
Environment=PORT=8080

[Install]
WantedBy=multi-user.target
